{
  "source": "css/css-syntax/anb-serialization.html",
  "kind": "anb",
  "tests": [
    {
      "input": "1",
      "expected": "1"
    },
    {
      "input": "+1",
      "expected": "1"
    },
    {
      "input": "-1",
      "expected": "-1"
    },
    {
      "input": "0n + 0",
      "expected": "0"
    },
    {
      "input": "0n + 1",
      "expected": "1"
    },
    {
      "input": "0n - 1",
      "expected": "-1"
    },
    {
      "input": "1n",
      "expected": "n"
    },
    {
      "input": "1n - 0",
      "expected": "n"
    },
    {
      "input": "1n + 1",
      "expected": "n+1"
    },
    {
      "input": "1n - 1",
      "expected": "n-1"
    },
    {
      "input": "-1n",
      "expected": "-n"
    },
    {
      "input": "-1n - 0",
      "expected": "-n"
    },
    {
      "input": "-1n + 1",
      "expected": "-n+1"
    },
    {
      "input": "-1n - 1",
      "expected": "-n-1"
    },
    {
      "input": "+n+1",
      "expected": "n+1"
    },
    {
      "input": "-n-1",
      "expected": "-n-1"
    },
    {
      "input": "n + 0",
      "expected": "n"
    },
    {
      "input": "n - 0",
      "expected": "n"
    },
    {
      "input": "2n + 2",
      "expected": "2n+2"
    },
    {
      "input": "-2n - 2",
      "expected": "-2n-2"
    }
  ]
}
