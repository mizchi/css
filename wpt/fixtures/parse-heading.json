      "expected": [
        ":heading(2n+1)"
      ]
    },
    {
      "kind": "invalid",
      "input": ":heading(2n+2)",
      "expected": [
        ":heading(2n+2)"
      ]
    },
    {
      "kind": "invalid",
      "input": ":heading(-n+3)",
      "expected": [
        ":heading(-n+3)"
      ]
    },
    {
      "kind": "invalid",
      "input": ":heading(2n, 3n)",
      "expected": [
        ":heading(2n, 3n)"
      ]
    },
    {
