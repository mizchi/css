  let name = match self {
    None => "None"
    Inset => "Inset"
    Groove => "Groove"
    Outset => "Outset"
    Ridge => "Ridge"
    Dotted => "Dotted"
    Dashed => "Dashed"
    Solid => "Solid"
    Double => "Double"
    Hidden => "Hidden"
